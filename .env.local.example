# Supabase project URL. Used by browser and server Supabase clients.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous public key. Safe for client-side usage with RLS enabled.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Server-only admin key; never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# LINE Login channel ID from LINE Developers console.
LINE_CHANNEL_ID=

# LINE Login channel secret. Server-only.
LINE_CHANNEL_SECRET=

# Public LINE OAuth callback URL, usually https://your-domain.com/api/auth/callback.
NEXT_PUBLIC_LINE_CALLBACK_URL=

# ECPay payment merchant ID.
ECPAY_MERCHANT_ID=

# ECPay payment hash key. Server-only.
ECPAY_HASH_KEY=

# ECPay payment hash IV. Server-only.
ECPAY_HASH_IV=

# ECPay payment endpoint. Use payment-stage.ecpay.com.tw for sandbox.
ECPAY_API_URL=

# ECPay logistics merchant ID.
ECPAY_LOGISTICS_MERCHANT_ID=

# ECPay logistics hash key. Server-only.
ECPAY_LOGISTICS_HASH_KEY=

# ECPay logistics hash IV. Server-only.
ECPAY_LOGISTICS_HASH_IV=

# Imagine Art API key for background removal and image generation. Server-only.
IMAGINE_ART_API_KEY=

# Railway/FastAPI card generation service base URL.
PYTHON_API_URL=

# Shared API key used by Next.js to authenticate requests to the Python API. Server-only.
PYTHON_API_KEY=

# Canonical public app URL, for redirects, QR codes, NFC URLs, and webhooks.
NEXT_PUBLIC_APP_URL=

# Secret used for app-level signing/encryption where required. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Optional Sentry DSN for server-side error monitoring.
SENTRY_DSN=

# Optional Sentry DSN for client-side error monitoring.
NEXT_PUBLIC_SENTRY_DSN=
