# Shared secret — must match PYTHON_API_KEY in Next.js .env
PYTHON_API_KEY=your-strong-random-secret

# Supabase credentials (service role — never expose publicly)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# App domain
DOMAIN=furchic.com
APP_URL=https://furchic.com

# Supabase Storage bucket for generated cards
CARD_STORAGE_BUCKET=card-prints
